# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_random_hex_chars

# SQLite path (Railway: use /app/data/db.sqlite3 with a volume mounted at /app/data)
DATABASE_URL=sqlite:///./data/db.sqlite3

# Directory where MP3s are stored (Railway: use /app/audio with a volume mounted at /app/audio)
AUDIO_DIR=audio

# Public URL of this service (no trailing slash)
BASE_URL=http://localhost:8000

# Email — use ONE of these options:
# Option A: Resend (recommended — free tier, easy setup: https://resend.com)
RESEND_API_KEY=

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FROM_EMAIL=briefings@yourdomain.com
